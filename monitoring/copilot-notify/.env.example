# Copilot Notify — Configuration Template
# Copy to .env and fill in values. NEVER commit .env to git.

# Telegram bot token (from @BotFather)
NOTIFY_BOT_TOKEN=

# Telegram user ID allowed to interact with the bot
ALLOWED_USER_ID=

# HMAC-SHA256 signature of ALLOWED_USER_ID — generated by setup.mjs
# Change user ID with: node setup.mjs --set-user-id <new_id>
ALLOWED_USER_ID_SIG=

# Secret key used to sign the user ID — keep this safe, never share
NOTIFY_SECRET=

# Human-readable name for this Copilot instance (shown in all messages)
# Default: hostname/repo-directory
INSTANCE_NAME=
