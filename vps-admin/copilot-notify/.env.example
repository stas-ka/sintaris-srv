# Copilot Notify v2 — Configuration Template
# Copy to .env and fill in values. NEVER commit .env to git.

# Telegram bot token (from @BotFather)
NOTIFY_BOT_TOKEN=

# Telegram user ID allowed to interact with the bot
ALLOWED_USER_ID=

# HMAC-SHA256 signature of ALLOWED_USER_ID — generated by setup.mjs
# Change user ID: node setup.mjs --set-user-id <new_id>
ALLOWED_USER_ID_SIG=

# Secret key used to sign the user ID — keep safe, never share
NOTIFY_SECRET=

# Human-readable name for this Copilot instance (shown in all messages)
# Default: hostname/current-directory
INSTANCE_NAME=

# HTTP port for MCP SSE transport (default: 7340)
NOTIFY_PORT=7340

# State persistence directory (default: /tmp; Docker: /data via volume)
STATE_DIR=
