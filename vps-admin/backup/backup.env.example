# =============================================================================
# sintaris-backup .env — Configuration for backup.sh, recover.sh, notify-event.sh
# =============================================================================
# Copy this file to /opt/sintaris-backup/.env on the VPS and fill in real values.
# NEVER commit this file with real credentials — it is gitignored.
# =============================================================================

# Telegram bot token and chat ID (same values as monitor .env)
TG_BOT_TOKEN=your_bot_token_here
TG_CHAT_ID=your_chat_id_here

# Mount point where backup archives are stored.
# Must be a mounted volume (NFS, extra disk, cloud storage mount, etc.)
# For testing use a local directory: /tmp/sintaris-backup-test
BACKUP_MOUNT=/mnt/sintaris-backup

# Number of daily backup sets to retain (older ones are deleted automatically)
BACKUP_RETENTION_DAYS=7

# Whether to back up raw mail data at /var/mail/vhosts/ (can be very large)
# Set to "yes" to enable. Default: no
BACKUP_MAIL_DATA=no

# MySQL root credentials (for mysqldump — leave empty if using .my.cnf or auth plugin)
# MYSQL_ROOT_PASS=

# PostgreSQL superuser (default: postgres, uses peer auth via sudo -u postgres)
# PG_SUPERUSER=postgres
