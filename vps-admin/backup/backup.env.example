# =============================================================================
# sintaris-backup .env — Configuration for backup.sh, recover.sh, notify-event.sh
# =============================================================================
# Copy this file to /opt/sintaris-backup/.env on the VPS and fill in real values.
# NEVER commit this file with real credentials — it is gitignored.
# =============================================================================

# Telegram bot token and chat ID (same values as monitor .env)
TG_BOT_TOKEN=your_bot_token_here
TG_CHAT_ID=your_chat_id_here

# Mount point where backup archives are stored.
# Must be a mounted volume (NFS, extra disk, cloud storage mount, etc.)
# For testing use a local directory: /tmp/sintaris-backup-test
BACKUP_MOUNT=/mnt/sintaris-backup

# Number of daily backup sets to retain (older ones are deleted automatically)
BACKUP_RETENTION_DAYS=7

# Whether to back up raw mail data at /var/mail/vhosts/ (can be very large)
# Set to "yes" to enable. Default: no
BACKUP_MAIL_DATA=no

# Space-separated list of Docker volume names to skip during backup.
# Useful for large media/data volumes (e.g. Nextcloud user files).
# Example: VOLUMES_SKIP="nextcloud-docker_nextcloud"
VOLUMES_SKIP=

# MySQL root credentials (for mysqldump — leave empty if using .my.cnf or auth plugin)
# MYSQL_ROOT_PASS=

# PostgreSQL superuser (default: postgres, uses peer auth via sudo -u postgres)
# PG_SUPERUSER=postgres

# =============================================================================
# image-backup.py — Provider image/snapshot credentials
# =============================================================================

# --- Netcup (dev2null.de) ---
# How to get:
#   1. Log in to https://www.customercontrolpanel.de
#   2. Master Data → API → Manage API keys → Create new key
#   3. Customer number shown top-right on CCP
#   4. Server name shown in SCP at https://www.servercontrolpanel.de
NETCUP_CUSTOMER_ID=
NETCUP_API_KEY=
NETCUP_API_PASS=
NETCUP_SERVER_NAME=

# --- IONOS (dev2null.website) ---
# Option A: IONOS Cloud DCD (if server is on IONOS Cloud)
#   Log in to https://dcd.ionos.com → Management → API Keys → Generate Token
IONOS_API_TOKEN=
IONOS_SERVER_ID=
IONOS_DATACENTER_ID=

# Option B: IONOS Cloud Basic Auth (alternative to token)
# IONOS_USERNAME=
# IONOS_PASSWORD=

# Note: Legacy IONOS VPS (dev2null.website) has no REST API.
# Snapshots must be created manually at https://my.ionos.com
# Set the above Cloud credentials only if/when migrated to IONOS Cloud.
