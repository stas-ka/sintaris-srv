# Copilot Bridge — environment configuration
# Copy to .env and adjust values.

# ── Server ────────────────────────────────────────────────────────────────────
COPILOT_BRIDGE_HOST=127.0.0.1
COPILOT_BRIDGE_PORT=8765

# Optional bearer token — if set, clients must send  Authorization: Bearer <key>
# Leave empty to disable auth (recommended for local-only use).
COPILOT_BRIDGE_API_KEY=

# ── GitHub token ──────────────────────────────────────────────────────────────
# Leave empty to auto-detect via `gh auth token` (recommended).
GH_TOKEN=

# ── Provider selection ────────────────────────────────────────────────────────
# auto         → try copilot → github_models → gh_cli (recommended)
# copilot      → GitHub Copilot API only (requires active Copilot subscription)
# github_models→ GitHub Models API only  (free tier: gpt-4o-mini, llama, etc.)
# gh_cli       → gh copilot suggest CLI  (limited — commands/explanations only)
COPILOT_PROVIDER=auto

# Default model to use when client doesn't specify one.
# For github_models: gpt-4o | gpt-4o-mini | Meta-Llama-3.1-70B-Instruct | …
# For copilot:       gpt-4o | claude-3.5-sonnet | …
COPILOT_MODEL=gpt-4o

# ── Generation defaults ───────────────────────────────────────────────────────
DEFAULT_MAX_TOKENS=2048
DEFAULT_TEMPERATURE=0.7

# HTTP timeout for upstream API calls (seconds)
COPILOT_UPSTREAM_TIMEOUT=120

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
