# Copy this file to .env and fill in your values
# .env is gitignored — NEVER commit it — all secrets live here only

# dev2null.de (main production VPS — SSH key auth)
VPS_HOST=dev2null.de
VPS_USER=stas
VPS_PASS=
VPS_SSH_PORT=22

# dev2null.website (VPN/proxy server — password auth)
WEB_HOST=dev2null.website
WEB_USER=boh
WEB_PASS=

# PostfixAdmin
PFA_DB_PASS=
PFA_SETUP_PASS=

# PostgreSQL users (dev2null.de)
PG_USER_POSTGRES=postgres
PG_PASS_POSTGRES=
PG_USER_N8N=n8n_user
PG_PASS_N8N=
PG_USER_N8N_TEST=n8n_user_test
PG_PASS_N8N_TEST=
PG_USER_ESPO=espouser
PG_PASS_ESPO=
PG_USER_SINTARIS_CRM=sintaris_crm
PG_PASS_SINTARIS_CRM=

# Telegram monitoring bot
TG_BOT_TOKEN=
TG_CHAT_ID=

# Telegram Copilot notify bot (MCP server — bidirectional)
NOTIFY_BOT_TOKEN=
NOTIFY_USER_ID=

# Local dev stack (local-dev/.env has its own file)
# See local-dev/.env.example

# =============================================================================
# image-backup.py — Provider snapshot credentials
# =============================================================================

# Netcup (dev2null.de) — SCP API
# Get from: https://www.customercontrolpanel.de → Master Data → API
NETCUP_CUSTOMER_ID=
NETCUP_API_KEY=
NETCUP_API_PASS=
NETCUP_SERVER_NAME=

# IONOS Cloud (dev2null.website — only if on IONOS Cloud DCD, not legacy VPS)
# Get from: https://dcd.ionos.com → Management → API Keys
IONOS_API_TOKEN=
IONOS_SERVER_ID=
IONOS_DATACENTER_ID=
