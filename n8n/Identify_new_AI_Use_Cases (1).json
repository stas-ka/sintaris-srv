      "parameters": {
        "jsCode": "const crypto = require('crypto');\n\n// Zugriff auf die Ideen aus GPT\nconst useCases = items[0].json.message.content.UseCases;\n\n// Aktueller Zeitstempel (einmal erzeugen, für alle gleich)\nconst now = new Date().toISOString();\n\nreturn useCases.map(useCase => {\n  const base = useCase.Titel ;\n  const hash = crypto.createHash('md5').update(base).digest('hex').slice(0, 6);\n\n  return {\n    json: {\n      ID: hash,\n      Titel: useCase.Titel,\n      Description: useCase.Description,\n      Potential_customers: useCase.Potential_customers,\n      Financial_potential_to_earn: useCase.Financial_potential_to_earn,\n      Costs_to_realize_in_hours: useCase.Costs_to_realize_in_hours,\n      Perspective_marketing_ranking: useCase.Perspective_marketing_ranking,\n      Source_links: useCase.Source_links,\n      Created_at: now  // ⏱ Zeitstempel \n    }\n  };\n});\n"
      },
