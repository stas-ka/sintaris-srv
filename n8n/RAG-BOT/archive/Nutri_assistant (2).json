        "jsCode": "const inputText = $json.output || $json.text || $json.message || \"\";\n\nfunction closeUnmatchedSymbols(text, symbol) {\n  const count = (text.match(new RegExp(`\\\\${symbol}`, 'g')) || []).length;\n  // Wenn ungerade Anzahl -> fehlt ein Abschlusszeichen\n  if (count % 2 !== 0) {\n    return text + symbol;\n  }\n  return text;\n}\n\n// Für alle typischen Markdown-V1-Symbole prüfen:\nlet safeText = inputText;\n['*', '_', '`'].forEach((symbol) => {\n  safeText = closeUnmatchedSymbols(safeText, symbol);\n});\n\n// Für []-Klammern extra check:\nconst openBrackets = (safeText.match(/\\[/g) || []).length;\nconst closeBrackets = (safeText.match(/\\]/g) || []).length;\nif (openBrackets > closeBrackets) {\n  safeText += ']';\n} else if (closeBrackets > openBrackets) {\n  safeText = '[' + safeText;\n}\n\n// Чтение всех данных\nconst session_data = $execution.customData.getAll();\n\nconsole.log(\"CustomData:\", session_data);\n// Возврат как JSON-результат\nconst text =safeText;\nreturn [\n  {\n    json: {\n      text,\n      session_data\n    }\n  }\n];"
