document.addEventListener('DOMContentLoaded',t_setvisRecs);}})();</script></head> <body class="t-body" style="margin:0;"> <!--allrecords--> <div id="allrecords" class="t-records" data-hook="blocks-collection-content-node" data-tilda-project-id="1661601" data-tilda-page-id="66375279" data-tilda-page-alias="strateg" data-tilda-formskey="91ce7b800a4a19dd0af4423a5cb30071" data-tilda-stat-scroll="yes" data-tilda-lazy="yes" data-tilda-root-zone="com" data-tilda-project-headcode="yes"> <div id="rec932594566" class="r t-rec t-rec_pt_45 t-rec_pb_0" style="padding-top:45px;padding-bottom:0px; " data-record-type="476"> <!-- T476 --> <!-- cover --> <div class="t-cover" id="recorddiv932594566"bgimgfield="img"style="height:100vh;background-image:url('https://thb.tildacdn.com/tild6339-6336-4032-b430-616333313731/-/resize/20x/strateg.jpg');"> <div class="t-cover__carrier" id="coverCarry932594566"data-content-cover-id="932594566"data-content-cover-bg="https://static.tildacdn.com/tild6339-6336-4032-b430-616333313731/strateg.jpg"data-display-changed="true"data-content-cover-height="100vh"data-content-cover-parallax="fixed"data-content-use-image-for-mobile-cover=""style="height:100vh; "itemscope itemtype="http://schema.org/ImageObject"><meta itemprop="image" content="https://static.tildacdn.com/tild6339-6336-4032-b430-616333313731/strateg.jpg"></div> <div class="t-cover__filter" style="height:100vh;background-image: -moz-linear-gradient(top, rgba(0,0,0,0.20), rgba(0,0,0,0.30));background-image: -webkit-linear-gradient(top, rgba(0,0,0,0.20), rgba(0,0,0,0.30));background-image: -o-linear-gradient(top, rgba(0,0,0,0.20), rgba(0,0,0,0.30));background-image: -ms-linear-gradient(top, rgba(0,0,0,0.20), rgba(0,0,0,0.30));background-image: linear-gradient(top, rgba(0,0,0,0.20), rgba(0,0,0,0.30));filter: progid:DXImageTransform.Microsoft.gradient(startColorStr='#cc000000', endColorstr='#b2000000');"></div> <div class="t476"> <div class="t-container"> <div class="t476__col t-width t-width_8"> <div class="t-cover__wrapper t-valign_middle" style="height:100vh;"> <div class="t476__wrapper" data-hook-content="covercontent"> <div class="t476__content"> <div class="t476__title t-title t-title_md t-margin_auto" field="title"><strong style="line-height: 14px; font-size: 32px;">AI Контент-Стратег — </strong><strong style="line-height: 14px; font-size: 26px;">НОВЫЙ СПОСОБ ВЫСТРАИВАТЬ СТАБИЛЬНЫЕ ПРОДАЖИ ЧЕРЕЗ СОЦСЕТИ</strong></div> <div class="t476__descr t-descr t-descr_md t-margin_auto" field="descr"><div style="text-align: left; font-size: 18px;" data-customstyle="yes"><strong>Без выгорания, нервотрепки и потери времени. Независимо от твоего настроения и погоды за окном.</strong></div></div> </div> </div> </div> </div> </div> </div> </div> <style> #rec932594566 .t476__descr{font-size:18px;}</style> </div> <div id="rec932594571" class="r t-rec t-rec_pt_45 t-rec_pb_0" style="padding-top:45px;padding-bottom:0px; " data-record-type="483"> <!-- T483 --> <div class="t483"> <div class="t-container t-align_center"> <div class="t-col t-col_8 t-prefix_2"> <div
class="t483__descr t-descr t-descr_xxxl t-margin_auto"
field="descr"> <div style="font-size: 20px; text-align: left;" data-customstyle="yes"><p style="text-align: center;"><strong style="color: rgb(236, 109, 57); font-size: 26px;">НОВАЯ РЕАЛЬНОСТЬ УЖЕ НАСТУПИЛА</strong><strong style="color: rgb(23, 34, 115); font-size: 26px;"> </strong></p><br /><p style="text-align: left;"><span style="font-size: 18px; color: rgb(0, 0, 0); font-family: Arial;">Пока одни продолжают выдыхаться в сторис, </span><span style="font-size: 18px; color: rgb(0, 0, 0);">выдавливать из себя «контент с душой» и</span><span style="font-size: 18px; color: rgb(0, 0, 0); font-family: Arial;"> ломают голову над яркими заголовками, другие (открытые к новому), учатся делегировать и нанимать на работу ИИ-помощников.</span></p></div> </div> </div> </div> </div> <style> #rec932594571 .t483__descr{font-size:18px;font-family:'Arial';}#rec932594571 .t483__text{font-size:18px;}</style> </div> <div id="rec932594576" class="r t-rec t-rec_pt_45 t-rec_pb_0" style="padding-top:45px;padding-bottom:0px;background-color:#f0f0f0; " data-record-type="483" data-bg-color="#f0f0f0"> <!-- T483 --> <div class="t483"> <div class="t-container t-align_center"> <div class="t-col t-col_8 t-prefix_2"> <div
class="t483__descr t-descr t-descr_xxxl t-margin_auto"
field="descr"> <div style="font-size: 20px; text-align: left;" data-customstyle="yes"><strong style="font-family: Arial; font-size: 18px;">Представь, ты просто открываешь чат с ИИ, и за 15–30 минут получаешь:</strong><br /><span style="font-family: Arial; font-size: 18px;"> </span><br /><ul><li data-list="bullet"><span style="font-family: Arial; font-size: 18px;">структурный контент-план минимум на неделю, </span></li><li data-list="bullet"><span style="font-family: Arial; font-size: 18px;">десятки небанальных идей для эфиров и интерактивов, </span></li><li data-list="bullet"><span style="font-family: Arial; font-size: 18px;">пост, который хочется сохранить,</span></li><li data-list="bullet"><span style="font-family: Arial; font-size: 18px;">логику прогрева, которая ведёт к реакциям и заявкам.</span></li></ul><span style="font-family: Arial; font-size: 18px;">Без зависаний, без белого листа, без прокрастинации.</span><br /><span style="font-family: Arial; font-size: 18px;">Контент готов — ты свободна.</span><br /><span style="font-family: Arial; font-size: 18px;">И всё это не «по шаблону», а с ощущением, что ты сама написала. Убедительно, интересно, экспертно, именно в твоем стиле.</span><br /><br /><span style="font-family: Arial; font-size: 18px;">И главное, всё это</span><br /><ul><li data-list="bullet"><span style="font-family: Arial; font-size: 18px;">без «выложить бы хоть что-то».</span></li><li data-list="bullet"><span style="font-family: Arial; font-size: 18px;">без «а кто это вообще увидит?»</span></li><li data-list="bullet"><span style="font-family: Arial; font-size: 18px;">без «что-то я опять не писала неделю…»</span></li></ul><br /><span style="font-family: Arial; font-size: 18px;">Запустив AI Контент-Стратега сегодня, уже через пару часов ты получишь готовый контент на неделю, который звучит как ты. А порой и лучше. </span><br /><strong style="font-family: Arial; font-size: 18px;">Идеи и креатив AI Контент-Стратега удивляют даже контент-мейкеров со стажем.</strong><br /><br /><span style="font-family: Arial; font-size: 18px;">И это не мечты, а реальность:</span><br /><span style="font-size: 18px;">📌</span><span style="font-size: 18px; font-family: Arial;">У тебя больше нет проблем о чем говорить с аудиторией и как ее привлечь.</span><br /><span style="font-family: Arial; font-size: 18px;">📌 У тебя больше нет паники: «о чем говорить сегодня?»</span><br /><span style="font-family: Arial; font-size: 18px;">📌 Ты не зависишь от вдохновения, фрилансеров и хаоса в голове.</span><br /><span style="font-family: Arial; font-size: 18px;">📌 У тебя заранее есть готовый контент, который прогревает и ведёт к продажам.</span><br /><span style="font-family: Arial; font-size: 18px;">📌 Ты выкладываешь публикации и видишь заявки.</span><br /><span style="font-family: Arial; font-size: 18px;">📌 У тебя появилась система, а вместе с ней ощущение, что ты снова управляешь процессом.</span><br /><span style="font-family: Arial; font-size: 18px;">Ты спокойна, уверена, чувствуешь себя в потоке.</span><br /><strong style="font-family: Arial; font-size: 18px;">Контент — это не боль и выгорание, а опора и точка роста.</strong><br /><br /></div> </div> </div> </div> </div> </div> <div id="rec932617366" class="r t-rec t-rec_pt_90 t-rec_pb_90" style="padding-top:90px;padding-bottom:90px;background-color:#ffffff; " data-record-type="180" data-bg-color="#ffffff"> <!-- T165 --> <div class="t165"> <div class="t-container"> <div class="t165__col-top t-col t-col_6 t-prefix_1 t165__vtop t165__left"> <div class="t165__textwrapper"> <div class="t165__title t-heading t-heading_md" field="title"><div style="font-size: 28px; line-height: 36px;" data-customstyle="yes"><span style="color: rgb(51, 51, 51);">меня зовут Инна Шоплик</span></div></div> <div class="t165__text t-text t-text_sm" field="text"><div style="font-size: 18px;" data-customstyle="yes"><span style="color: rgb(0, 0, 0);">Уже несколько лет я занимаюсь продвижением экспертов и руковожу онлайн-центром нутрициологии.</span><strong style="color: rgb(0, 0, 0);"> </strong><br /><strong style="color: rgb(0, 0, 0);">Существует аксиома: если ты выбрал бизнес в интернете — вести соцсети обязательно. </strong><span style="color: rgb(0, 0, 0);">Не поспоришь...</span><br /><br /><strong style="color: rgb(0, 0, 0);">Только вот беда:</strong><span style="color: rgb(0, 0, 0);"> я не люблю вести соцсети.</span><br /><ul><li data-list="bullet" style="color: rgb(0, 0, 0);"><span style="color: rgb(0, 0, 0);">Сторис, Reels, монтаж, визуал — б-р-р-р… Не моё.</span></li><li data-list="bullet" style="color: rgb(0, 0, 0);"><span style="color: rgb(0, 0, 0);">Тексты ради текстов не вдохновляли. Контент шёл рывками.</span></li><li data-list="bullet" style="color: rgb(0, 0, 0);"><span style="color: rgb(0, 0, 0);">Нанимала SMM-специалистов, но постоянно сталкивалась с тем, что они не понимали моих смыслов, а я не хотела «вещать чушь ради охватов».</span></li></ul><strong style="color: rgb(0, 0, 0);">И самое обидное</strong><span style="color: rgb(0, 0, 0);"> — я платила зарплату из своего кармана, а продажи ее не окупали. Один месяц, второй... Результаты не добавляли оптимизма.</span><br /><span style="color: rgb(0, 0, 0);">❌ Тратить ресурсы «на авось» — точно не мой путь.</span></div></div> </div> </div> <div class="t-col t-col_4 t165__vtop t165__left"> <img class="t165__img t-img"
src="https://thb.tildacdn.com/tild3736-6331-4363-b936-653139333835/-/empty/IMG_6256.jpg" data-original="https://static.tildacdn.com/tild3736-6331-4363-b936-653139333835/IMG_6256.jpg"
imgfiled="img"
alt=""> </div> </div> </div> <style> #rec932617366 .t165__uptitle{font-size:22px;color:#333333;}#rec932617366 .t165__title{font-size:22px;color:#333333;}#rec932617366 .t165__text{font-size:22px;color:#333333;}</style> </div> <div id="rec932959721" class="r t-rec t-rec_pt_45 t-rec_pb_0" style="padding-top:45px;padding-bottom:0px;background-color:#f0f0f0; " data-record-type="483" data-bg-color="#f0f0f0"> <!-- T483 --> <div class="t483"> <div class="t-container t-align_center"> <div class="t-col t-col_8 t-prefix_2"> <div
class="t483__descr t-descr t-descr_xxxl t-margin_auto"
field="descr"> <div style="font-size: 18px; text-align: left;" data-customstyle="yes"><strong>А еще я много общаюсь с другими экспертами и вижу: эта проблема — массовая.</strong><br /><strong>Почему люди выгорают на соцсетях и пишут «потому что надо»?</strong></div> </div> </div> </div> </div> <style> #rec932959721 .t483__descr{font-size:18px;}#rec932959721 .t483__text{font-size:18px;}</style> </div> <div id="rec932938456" class="r t-rec t-rec_pt_45 t-rec_pb_0" style="padding-top:45px;padding-bottom:0px; " data-record-type="483"> <!-- T483 --> <div class="t483"> <div class="t-container t-align_center"> <div class="t-col t-col_8 t-prefix_2"> <div
class="t483__descr t-descr t-descr_xxxl t-margin_auto"
field="descr"> <div style="font-size: 20px; text-align: left;" data-customstyle="yes"><strong style="font-size: 18px;">Да просто ранее нам навязали модель, в которой: </strong><br /><span style="font-family: Arial; font-size: 18px;">— надо «быть на связи» 24/7,</span><br /><span style="font-family: Arial; font-size: 18px;">— делать «прогрев из боли»,</span><br /><span style="font-family: Arial; font-size: 18px;">— вести по 10 сторис ежедневно, даже когда тебе плохо или некогда,</span><br /><span style="font-family: Arial; font-size: 18px;">— не забывать быть харизматичной, глубокой и «светить собой», </span><br /><strong style="font-family: Arial; font-size: 18px;">а еще покупать курсы, обучаться, и узнавать о трендах соцсетей на платных эфирах.</strong><br /><br /><strong style="color: rgb(236, 109, 57); font-family: Arial; font-size: 18px;">Но если эта модель работает, то почему у большинства экспертов нет заявок и продаж?</strong><br /><strong style="color: rgb(236, 109, 57); font-family: Arial; font-size: 18px;">Почему сарафан кормит, а Инстаграм и иже с ним – нет?</strong><br /><br /><strong style="font-family: Arial; font-size: 18px;">Ответ прост: </strong><br /><span style="font-family: Arial; font-size: 18px;">быть рабой контента постоянно – невозможно. Ты выдыхаешься и начинаешь делать перерывы. </span><br /><strong style="font-family: Arial; font-size: 18px;">Итог:</strong><br /><ul><li data-list="bullet"><span style="font-family: Arial; font-size: 18px;">Контент-пауза = отписки и падение заявок.</span></li><li data-list="bullet"><span style="font-family: Arial; font-size: 18px;">Нет Reels — нет охвата.</span></li><li data-list="bullet"><span style="font-family: Arial; font-size: 18px;">Нет поста — нет диалога.</span></li><li data-list="bullet"><span style="font-family: Arial; font-size: 18px;">Нет сторис — тебя как будто и не существует.</span></li></ul><strong style="font-family: Arial; font-size: 18px;">Ты больше не человек, у которого есть жизнь.</strong><br /><strong style="font-family: Arial; font-size: 18px;">Ты — медиа-аватар, который обязан «производить контент» ради лайков, охватов и в надежде на продажи.</strong><br /><br /><strong style="font-family: Arial; font-size: 18px;">И при этом:</strong><br /><ul><li data-list="bullet"><span style="font-family: Arial; font-size: 18px;">всё рушится при первом кризисе,</span></li><li data-list="bullet"><span style="font-family: Arial; font-size: 18px;">ты не можешь делегировать, потому что всё держится на тебе,</span></li><li data-list="bullet"><span style="font-family: Arial; font-size: 18px;">ты каждый месяц начинаешь с нуля.</span></li></ul><span style="font-family: Arial; font-size: 18px;">Стабильности — нет.</span><br /><span style="font-family: Arial; font-size: 18px;">Системы — нет.</span><br /><span style="font-family: Arial; font-size: 18px;">Повторяемости — нет.</span><br /><strong style="font-family: Arial; font-size: 18px;">А главное — нет опоры.</strong><br /><strong style="font-family: Arial; font-size: 18px;">Ты не знаешь: что сработает в следующий ра</strong><strong style="font-family: Arial;">з. </strong><strong style="font-family: Arial; font-size: 18px;">Бег по кругу...</strong></div> </div> </div> </div> </div> <style> #rec932938456 .t483__descr{font-size:18px;}#rec932938456 .t483__text{font-size:18px;}</style> </div> <div id="rec932594586" class="r t-rec t-rec_pt_45 t-rec_pb_30" style="padding-top:45px;padding-bottom:30px;background-color:#f0f0f0; " data-record-type="239" data-bg-color="#f0f0f0"> <!-- T210 --> <div class="t210"> <div class="t-container"> <div class="t-col t-col_10 t-prefix_2"> <div class="t-col t-col_5 t210__descrblock"> <div class="t-divider t210__line" style=""></div> <div class="t210__descr t-text-impact t-text-impact_sm" field="descr"><div style="color: rgb(236, 109, 57); font-size: 20px;" data-customstyle="yes"><strong style="color: rgb(236, 109, 57);">Всё изменилось буквально пару месяцев назад.</strong></div></div> </div> <div class="t-col t-col_8" style="margin:0; float:none; display:inherit;"> <div class="t210__text t-text t-text_md" field="text"><br /><br /><span style="font-size: 18px;">Ты заметила, что ИИ всё увереннее входит в нашу жизнь? 🙂</span><br /><span style="font-size: 18px;">Я решила не отставать и всерьёз взялась за нейросети: изучила, как они думают, на что способны. </span><br /><br /><strong style="font-size: 18px;">И знаешь, что выяснилось?! Это — революция!</strong><br /><span style="font-size: 18px;">ИИ в деле! И всё, что мы делаем, он делает в РАЗЫ быстрее!</span><br /><br /><span style="font-size: 18px;">Тексты, смыслы, идеи, планирование – ИИ справляется шедеврально.</span><br /><span style="font-size: 18px;">Можно посоветоваться, поспорить, уточнить, принять совместное решение. </span><br /><br /><br /></div> </div> </div> </div> </div> <style> #rec932594586 .t210__descr{font-size:18px;}#rec932594586 .t210__text{font-size:18px;}</style> </div> <div id="rec932594591" class="r t-rec t-rec_pt_45 t-rec_pb_0" style="padding-top:45px;padding-bottom:0px;background-color:#ffffff; " data-record-type="239" data-bg-color="#ffffff"> <!-- T210 --> <div class="t210"> <div class="t-container"> <div class="t-col t-col_10 t-prefix_2"> <div class="t-col t-col_5 t210__descrblock"> <div class="t-divider t210__line" style=""></div> <div class="t210__descr t-text-impact t-text-impact_sm" field="descr"><div style="color: rgb(236, 109, 57); font-size: 20px;" data-customstyle="yes"><strong>И вот что произошло после.</strong></div></div> </div> <div class="t-col t-col_8" style="margin:0; float:none; display:inherit;"> <div class="t210__text t-text t-text_md" field="text">Я обучила себе ИИ-помощника.<br /><ul><li data-list="bullet">Час на планирование и создание публикаций.</li><li data-list="bullet">Теперь контент выстроен по смыслам, структурно, органично.</li><li data-list="bullet">Я могу передать план ассистенту и сторисмейкеру.</li><li data-list="bullet">Выйти с кружком или прямым эфиром вообще не проблема. Идей масса. И все они вписываются в логику недели, а не идут от моего настроения.</li></ul>(Хотя, конечно, вдохновенные выходы никто не запрещает.🤗)<br /><br /><strong>У меня есть системный помощник, который работает как команда, но не требует ежемесячной зарплаты.</strong><br /><strong>И да, я больше не чувствую себя ленивой, глупой или неумехой, </strong>как это бывает, когда ты забрасываешь соцсети или не видишь выхопа от них.<br /><br /><br /></div> </div> </div> </div> </div> <style> #rec932594591 .t210__descr{font-size:18px;}#rec932594591 .t210__text{font-size:18px;}</style> </div> <div id="rec932974316" class="r t-rec t-rec_pt_45 t-rec_pb_45" style="padding-top:45px;padding-bottom:45px;background-color:#f0f0f0; " data-record-type="239" data-bg-color="#f0f0f0"> <!-- T210 --> <div class="t210"> <div class="t-container"> <div class="t-col t-col_10 t-prefix_2"> <div class="t-col t-col_5 t210__descrblock"> <div class="t-divider t210__line" style=""></div> <div class="t210__descr t-text-impact t-text-impact_sm" field="descr"><div style="color: rgb(236, 109, 57); font-size: 20px;" data-customstyle="yes"><strong>Контент я полностью делегировала нейросетям.</strong></div></div> </div> <div class="t-col t-col_8" style="margin:0; float:none; display:inherit;"> <div class="t210__text t-text t-text_md" field="text"><br /><span style="font-size: 18px;">Но не каждый готов тратить месяцы на освоение ИИ.</span><br /><br /><span style="font-size: 18px;">Поэтому я решила передать свои наработки в доступной абсолютно для всех форме и создала готовое решение —</span><br /><strong style="font-size: 18px;">ИИ-помощника «Контент-стратег», который станет твоим личным продюсером в соцсетях.</strong><br /><span style="font-size: 18px;">Этот продукт я бы с радостью дала самой себе 2 года назад😍. </span><br /><span style="font-size: 18px;">Вместо курсов по копирайтингу, продажам и художественным текстам.</span><br /><br /><span style="font-size: 18px;">AI Контент-Стратег — это новый маркетинговый инструмент, который работает в синхроне с тобой и забирает десятки задач на себя.</span></div> </div> </div> </div> </div> <style> #rec932974316 .t210__descr{font-size:18px;}#rec932974316 .t210__text{font-size:18px;}</style> </div> <div id="rec932594601" class="r t-rec t-rec_pt_45 t-rec_pb_0" style="padding-top:45px;padding-bottom:0px;background-color:#ffffff; " data-record-type="483" data-bg-color="#ffffff"> <!-- T483 --> <div class="t483"> <div class="t-container t-align_center"> <div class="t-col t-col_8 t-prefix_2"> <div
class="t483__descr t-descr t-descr_xxxl t-margin_auto"
field="descr"> <div style="font-size: 18px; text-align: left;" data-customstyle="yes"><p style="text-align: left;"><strong style="color: rgb(0, 0, 0); font-size: 18px;">Знаешь, сейчас есть две модели ведения соцсетей.</strong></p><br /><p style="text-align: left;"><span style="color: rgb(236, 109, 57);">Старая модель</span>: ты как батарейка. Пока есть заряд — генерируешь.</p><br /><span style="font-family: Arial;">Ты пишешь, когда есть вдохновение или когда «надо». </span><br /><span style="font-family: Arial;">Заказываешь тексты, пробуешь новые шаблоны. </span><br /><span style="font-family: Arial;">Каждый раз начинаешь с нуля и проходишь путь заново.</span><br /><span style="font-family: Arial;">Большинство моделей контента работают по принципу «пиши и надейся». </span><br /><br /><span style="font-family: Arial;">Но это не система. Это лотерея. А лотерея не может быть стабильной опорой.</span><br /><span style="font-family: Arial;">❌ Тебе дали чужую модель.</span><br /><span style="font-family: Arial;">❌ С чужими ресурсами.</span><br /><span style="font-family: Arial;">❌ С чужими ориентирами.</span><br /><span style="font-family: Arial;">А потом ты думаешь: «Ну, если у меня не выходит как у них — значит, проблема во мне».</span><br /><span style="font-family: Arial;">Нет. Проблема — в методе и системе.</span><br /><br /><strong style="font-family: Arial;">Ты просто летишь в Нидерланды… на рейсе до Норильска 🤷‍♀️.</strong><br /><br /></div> </div> </div> </div> </div> <style> #rec932594601 .t483__descr{font-size:18px;font-family:'Arial';}#rec932594601 .t483__text{font-size:18px;}</style> </div> <div id="rec933587176" class="r t-rec t-rec_pt_45 t-rec_pb_0" style="padding-top:45px;padding-bottom:0px;background-color:#f0f0f0; " data-record-type="483" data-bg-color="#f0f0f0"> <!-- T483 --> <div class="t483"> <div class="t-container t-align_center"> <div class="t-col t-col_8 t-prefix_2"> <div
class="t483__descr t-descr t-descr_xxxl t-margin_auto"
field="descr"> <div style="font-size: 18px; text-align: left;" data-customstyle="yes"><br /><p style="text-align: left;"><span style="color: rgb(236, 109, 57);">Новая модель</span>: система, которая работает даже когда ты отдыхаешь.</p><br /><p style="text-align: left;">Представь себе, что</p><ul><li data-list="bullet" style="text-align: left;">ты больше не выдыхаешься от контента</li><li data-list="bullet">нет вечного «что сегодня постить?»</li><li data-list="bullet">не нужно тащить всё на себе</li></ul><strong>Это и есть — AI Контент-Стратег. Не курс. Не шаблон. Не магия копирайтинга.</strong><br /><br />А рабочая система, которая:<br />— понимает, кто ты и что ты продаёшь<br />— выстраивает стратегию контента под твой продукт<br />— обучается твоему голосу<br />— и генерирует посты, сторис, Reels, как будто их пишешь ты<br /><br />И в результате:<br />📌 У тебя есть контент-воронка, которая ведёт к заявкам<br />📌 Ты перестаёшь начинать всё с нуля<br />📌 Контент работает, даже когда ты не в ресурсе<br />📌 Воронка не рушится, если ты уехала на ретрит или просто устала<br /><strong>И что особенно важно — тебе не нужно иметь команду, вдохновение или 1000 идей.</strong><br /><br />Ты просто открываешь чат с AI и получаешь готовый контент:<br /><ul><li data-list="bullet">в твоём стиле</li><li data-list="bullet">под твой продукт</li><li data-list="bullet">с точками прогрева и продаж</li></ul>А если что-то нужно донастроить — техподдержка всегда поможет. Ты не одна.<br /><br /><strong style="color: rgb(236, 109, 57);">Это система, которую ты один раз легко осваиваешь, внедряешь, и используешь снова и снова.</strong><br /><ul><li data-list="bullet">С любым продуктом.</li><li data-list="bullet">На любом этапе.</li><li data-list="bullet">С минимальными усилиями.</li></ul>И да, она уже работает у экспертов, у которых раньше не получалось.<br />Но об этом — в следующем блоке.<br /><br /></div> </div> </div> </div> </div> <style> #rec933587176 .t483__descr{font-size:18px;font-family:'Arial';}#rec933587176 .t483__text{font-size:18px;}</style> </div> <div id="rec932594636" class="r t-rec t-rec_pt_45 t-rec_pb_0" style="padding-top:45px;padding-bottom:0px; " data-record-type="483"> <!-- T483 --> <div class="t483"> <div class="t-container t-align_center"> <div class="t-col t-col_8 t-prefix_2"> <div
class="t483__descr t-descr t-descr_xxxl t-margin_auto"
field="descr"> <div style="font-size: 20px; text-align: left;" data-customstyle="yes"><strong style="font-size: 18px; font-family: Arial;">В чём секрет? Почему это работает, даже если раньше не работало ничего?</strong><br /><span style="font-size: 18px; font-family: Arial;">Смотри.</span><br /><span style="font-size: 18px; font-family: Arial;">Ты уже пробовала писать сама.</span><br /><span style="font-size: 18px; font-family: Arial;">Смотрела, как пишут другие.</span><br /><span style="font-size: 18px; font-family: Arial;">Брала шаблоны, проходила курсы, заказывала тексты.</span><br /><span style="font-size: 18px; font-family: Arial;">Но всё ломалось в одном месте — в смыслах.</span><br /><span style="font-size: 18px; font-family: Arial;">Контент, который не встроен в стратегию,</span><br /><span style="font-size: 18px; font-family: Arial;">не работает.</span><br /><span style="font-size: 18px; font-family: Arial;">Он может быть красивым, цепким, даже «вирусным» —</span><br /><span style="font-size: 18px; font-family: Arial;">но он не ведёт к продаже.</span><br /><br /><strong style="font-size: 18px; font-family: Arial;">AI Контент-Стратег работает по-другому.</strong><br /><ul><li data-list="bullet"><span style="font-size: 18px; font-family: Arial;">Он не генерит тексты «от балды».</span></li><li data-list="bullet"><span style="font-size: 18px; font-family: Arial;">Он не делает «что-то, лишь бы было».</span></li><li data-list="bullet"><span style="font-size: 18px; font-family: Arial;">Он опирается на твои смыслы.</span></li><li data-list="bullet"><span style="font-size: 18px; font-family: Arial;">На то, кому ты продаёшь.</span></li><li data-list="bullet"><span style="font-size: 18px; font-family: Arial;">На то, что он должен услышать, почувствовать, прожить , чтобы захотеть купить.</span></li></ul><br /><strong style="font-size: 18px; font-family: Arial;">Мы встроили в AI-помощника 3 ключевые вещи:</strong><br /><span style="font-size: 18px; font-family: Arial;">1.Психологию прогрева.</span><br /><span style="font-size: 18px; font-family: Arial;">2.Понимание, какие эмоции и барьеры есть у клиента на каждом этапе.</span><br /><span style="font-size: 18px; font-family: Arial;">3.Логику воронки.</span><br /><br /><span style="font-size: 18px; font-family: Arial;">Он работает как 3 в 1: смысловик, копирайтер, маркетолог с многолетним опытом и мирового уровня. Каждый пост, сторис и Reels — это шаг. Не «тема ради темы», а смысловая точка, ведущая к продаже.</span><br /><br /><strong style="font-size: 18px; font-family: Arial;">Результат?</strong><br /><ul><li data-list="bullet"><span style="font-size: 18px; font-family: Arial;">Ты создаёшь контент быстро.</span></li><li data-list="bullet"><span style="font-size: 18px; font-family: Arial;">Тексты — живые, точные, в цель.</span></li></ul><strong style="font-size: 18px; font-family: Arial;">И главное: они ведут к деньгам, потому что смыслы встроены, а структура — проверена.</strong><br /><span style="font-size: 18px; font-family: Arial;">Каждый элемент системы делает своё дело:</span><br /><span style="font-size: 18px; font-family: Arial;">✔️держит внимание,</span><br /><span style="font-size: 18px; font-family: Arial;">✔️формирует доверие,</span><br /><span style="font-size: 18px; font-family: Arial;">✔️прогревает,</span><br /><span style="font-size: 18px; font-family: Arial;">✔️продаёт.</span><br /><br /><span style="font-size: 18px; font-family: Arial;">А теперь...</span><br /><span style="font-size: 18px; font-family: Arial;">Хочешь увидеть, что именно ты получишь, если подключишься к </span><span style="font-size: 18px;">AI Контент-Стратег</span><span style="font-size: 18px; font-family: Arial;">?</span><br /><em style="font-size: 18px; font-family: Arial;">Если коротко: я собрала систему, в которую встроены твои смыслы, твоя энергия и стратегия продаж.</em><br /><em style="font-size: 18px; font-family: Arial;">Без усложнений. Без перегрузки. Без ожидания вдохновения</em><strong><em>.</em></strong><br /><br /></div> </div> </div> </div> </div> <style> #rec932594636 .t483__descr{font-size:18px;font-family:'Arial';}#rec932594636 .t483__text{font-size:18px;font-family:'Arial';}</style> </div> <div id="rec932594626" class="r t-rec t-rec_pt_45 t-rec_pb_0" style="padding-top:45px;padding-bottom:0px;background-color:#f0f0f0; " data-record-type="483" data-bg-color="#f0f0f0"> <!-- T483 --> <div class="t483"> <div class="t-container t-align_center"> <div class="t-col t-col_8 t-prefix_2"> <div
class="t483__descr t-descr t-descr_xxxl t-margin_auto"
field="descr"> <div style="font-size: 18px; text-align: left;" data-customstyle="yes"><strong style="font-size: 26px;">ВОТ ЧТО ВХОДИТ В AI Контент-Стратег:</strong><br /><br /><strong>📌 1. Глубокая распаковка твоей экспертности </strong><br /><span style="font-family: Arial;">Ты проходишь через стратегические вопросы,</span><br /><span style="font-family: Arial;">которые вытаскивают из тебя всё —</span><br /><span style="font-family: Arial;">от сильных сторон до боли клиента.</span><br /><strong>Это как мини-сессия с продюсером и копирайтером в одном лице. Только вместо 3 часов работы — 20 минут с AI.</strong><br /><br /><strong>📌 2. Контент-логика и путь клиента</strong><br /><span style="font-family: Arial;">Ты получаешь не просто набор тем, а стратегию:</span><br /><span style="font-family: Arial;">— что клиент должен понять,</span><br /><span style="font-family: Arial;">— что почувствовать,</span><br /><span style="font-family: Arial;">— и в какой последовательности, чтобы захотеть купить.</span><br /><br /><strong>📌 4. Контент-план на 7 и более дней</strong><br /><span style="font-family: Arial;">Посты, сторис, эфиры, интерактивы — структурно, по целям, под твой продукт.</span><br /><br /><strong>📌 5. Готовые алгоритмы прогревов</strong><br /><span style="font-family: Arial;">Ты можешь запустить продукт уже через 3 дня — без подготовки, без запусков и без стресса.</span><br /><br /><strong>📌 6. Поддержка в Telegram</strong><br /><span style="font-family: Arial;">Если что-то непонятно — техподдержка рядом. Помогаем, докручиваем, отвечаем.</span><br /><br /><strong style="color: rgb(236, 109, 57);">И самое важное. Эта система работает, даже если:</strong><br /><ul><li data-list="bullet"><strong>ты не пишешь каждый день, </strong></li><li data-list="bullet"><strong>у тебя нет помощников, </strong></li><li data-list="bullet"><strong>ты устала и хочешь просто выдохнуть.</strong></li></ul></div> </div> </div> </div> </div> <style> #rec932594626 .t483__descr{font-size:18px;}#rec932594626 .t483__text{font-size:18px;}</style> </div> <div id="rec932667816" class="r t-rec t-rec_pt_45 t-rec_pb_45" style="padding-top:45px;padding-bottom:45px; " data-animationappear="off" data-record-type="677"> <!-- T677 --> <div class="t677"> <div class="t-container t-container_flex"> <div class="t677__col t-col t-col_6 "> <div class="t677__row t677__row_3-images"> <div class="t677__tile t677__tile_left" itemscope itemtype="http://schema.org/ImageObject"> <meta itemprop="image" content="https://static.tildacdn.com/tild3633-3862-4736-a463-633536613965/Otzyv.jpg"> <div class="t677__bgimg t677__bgimg_1 t-bgimg" data-original="https://static.tildacdn.com/tild3633-3862-4736-a463-633536613965/Otzyv.jpg"
